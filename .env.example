# ==============================================================================
# Econ-App environment variables
# ==============================================================================
# Copy this file to `.env` and fill in the actual values.
# The `.env` file is gitignored and will never be committed.
#
#   cp .env.example .env
#
# ==============================================================================

# FRED API key — get a free one at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional: override default data directory
# ECON_APP_DATA_DIR=~/.econ-app/data

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# ECON_APP_LOG_LEVEL=INFO
